    "build": "npx prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "test": "jest --config ../test/backend/jest-unit.config.cjs",
    "test:watch": "jest --config ../test/backend/jest-unit.config.cjs --watch",
    "test:cov": "jest --config ../test/backend/jest-unit.config.cjs --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ../test/backend/jest-unit.config.cjs --runInBand",
